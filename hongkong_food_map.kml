<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>🍽️ 香港美食地图 — Coda 7月行程</name>
  <description>2026年7月香港2日游美食调研，按类型分色标注</description>

  <!-- 样式定义 -->
  <Style id="dimsum">
    <IconStyle>
      <color>ff0088ff</color>
      <scale>1.2</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/paddle/orange-stars.png</href></Icon>
    </IconStyle>
  </Style>
  <Style id="western">
    <IconStyle>
      <color>ff0000ff</color>
      <scale>1.1</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon>
    </IconStyle>
  </Style>
  <Style id="quick">
    <IconStyle>
      <scale>1.0</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon>
    </IconStyle>
  </Style>
  <Style id="dessert">
    <IconStyle>
      <color>ffff00ff</color>
      <scale>1.0</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/paddle/pink-circle.png</href></Icon>
    </IconStyle>
  </Style>
  <Style id="brunch">
    <IconStyle>
      <scale>1.0</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/paddle/ylw-circle.png</href></Icon>
    </IconStyle>
  </Style>
  <Style id="star">
    <IconStyle>
      <scale>1.3</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/paddle/red-stars.png</href></Icon>
    </IconStyle>
  </Style>
  <Style id="venue">
    <IconStyle>
      <scale>1.1</scale>
      <Icon><href>https://maps.google.com/mapfiles/kml/paddle/blu-diamond.png</href></Icon>
    </IconStyle>
  </Style>

  <!-- ===== 地标：行程锚点 ===== -->
  <Folder>
    <name>📍 行程锚点</name>
    <Placemark>
      <name>🎭 香港文化中心（看剧）</name>
      <description>7.25 音乐剧</description>
      <styleUrl>#venue</styleUrl>
      <Point><coordinates>114.1700,22.2935,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>⛰️ 太平山顶</name>
      <description>港岛必去</description>
      <styleUrl>#venue</styleUrl>
      <Point><coordinates>114.1508,22.2759,0</coordinates></Point>
    </Placemark>
  </Folder>

  <!-- ===== 早茶 / 点心 ===== -->
  <Folder>
    <name>☕ 早茶 / 点心</name>
    <Placemark>
      <name>⭐ 逸东轩 Yat Tung Heen</name>
      <description><![CDATA[<b>米一星粤式点心</b><br/>人均 HK$300–500<br/>佐敦站 C2 出口步行2分钟<br/>11:00–15:00, 18:00–23:00<br/>📞 建议提前订位<br/><br/>强推！离文化中心最近的高品质点心]]></description>
      <styleUrl>#star</styleUrl>
      <Point><coordinates>114.1718,22.3080,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>六安居 Luk On Kui</name>
      <description><![CDATA[<b>推车早茶（前蓮香居）</b><br/>人均 HK$100–150<br/>上环站 A2 出口步行5分钟<br/>香港少数仍保留推车点心的茶楼<br/>环境旧但体验原汁原味]]></description>
      <styleUrl>#dimsum</styleUrl>
      <Point><coordinates>114.1471,22.2877,0</coordinates></Point>
    </Placemark>
  </Folder>

  <!-- ===== 西餐正餐 ===== -->
  <Folder>
    <name>🍝 西餐正餐</name>
    <Placemark>
      <name>⭐ Bouillon Bistro Parisien</name>
      <description><![CDATA[<b>法国菜</b><br/>人均 HK$380–450（三道菜套餐$398）<br/>Google/Tripadvisor 4.5 · 485条评价<br/>上环 6 Pound Lane<br/>"随便点都不踩雷"数据验证为真]]></description>
      <styleUrl>#star</styleUrl>
      <Point><coordinates>114.1479,22.2852,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Giando Italian</name>
      <description><![CDATA[<b>意大利菜 — 全球50 Best Italy 第15名</b><br/>人均 午餐$328 / 晚餐$500+<br/>湾仔星街 · 金钟站步行8分钟<br/>全港意大利菜排名第一]]></description>
      <styleUrl>#western</styleUrl>
      <Point><coordinates>114.1682,22.2765,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>22 Ships</name>
      <description><![CDATA[<b>西班牙Tapas</b><br/>人均 HK$400–800<br/>中环PMQ · 周二至周日 12:00–23:00<br/>⚠️ 周一休息<br/>不收服务费 · 章鱼饭招牌]]></description>
      <styleUrl>#western</styleUrl>
      <Point><coordinates>114.1519,22.2834,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Chachawan</name>
      <description><![CDATA[<b>泰国东北Isaan菜</b><br/>人均 HK$200–400<br/>上环荷李活道206号<br/>招牌蟹肉蛋白炒饭 · 和Bouillon同区域]]></description>
      <styleUrl>#western</styleUrl>
      <Point><coordinates>114.1481,22.2856,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>La Vache!（中环店）</name>
      <description><![CDATA[<b>法式牛排 — 备选</b><br/>人均 HK$398固定套餐<br/>中环 48 Peel Street<br/>只有一道菜：牛排+无限薯条<br/>Coda不太想吃牛排，备选]]></description>
      <styleUrl>#western</styleUrl>
      <Point><coordinates>114.1528,22.2826,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>La Vache!（尖沙咀店）</name>
      <description><![CDATA[<b>法式牛排 — 备选</b><br/>人均 HK$398固定套餐<br/>尖沙咀 12 Hart Avenue]]></description>
      <styleUrl>#western</styleUrl>
      <Point><coordinates>114.1750,22.2979,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Grissini（君悦酒店）</name>
      <description><![CDATA[<b>意大利菜 · 维港海景</b><br/>人均 HK$800+<br/>湾仔 Grand Hyatt 2/F<br/>Google 4.4 · Tripadvisor 4.5<br/>高预算选项，卖点是海景]]></description>
      <styleUrl>#western</styleUrl>
      <Point><coordinates>114.1721,22.2814,0</coordinates></Point>
    </Placemark>
  </Folder>

  <!-- ===== 快餐 / 简餐 ===== -->
  <Folder>
    <name>🍜 快餐 / 简餐</name>
    <Placemark>
      <name>水门鸡饭</name>
      <description><![CDATA[<b>泰式鸡饭</b><br/>人均 HK$50–80<br/>尖沙咀金马伦道18号<br/>半只鸡$108 · "性价比封神"]]></description>
      <styleUrl>#quick</styleUrl>
      <Point><coordinates>114.1738,22.2982,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>麦文记面家</name>
      <description><![CDATA[<b>鲜虾云吞面</b><br/>人均 HK$40–60 · 必比登<br/>佐敦白加士街51号<br/>营业到凌晨00:30 — 看完剧当宵夜<br/>⚠️ 近年口碑下滑中]]></description>
      <styleUrl>#quick</styleUrl>
      <Point><coordinates>114.1705,22.3047,0</coordinates></Point>
    </Placemark>
  </Folder>

  <!-- ===== 甜品 / 消暑 ===== -->
  <Folder>
    <name>🍧 甜品 / 消暑</name>
    <Placemark>
      <name>⭐ Shari Shari 氷屋（尖沙咀）</name>
      <description><![CDATA[<b>日式刨冰</b><br/>人均 HK$45–90<br/>尖沙咀漆咸道南83-85A<br/>13:00–22:30<br/>7月消暑首选！看完剧散步可达]]></description>
      <styleUrl>#star</styleUrl>
      <Point><coordinates>114.1760,22.3002,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Shari Shari 氷屋（中环）</name>
      <description><![CDATA[<b>日式刨冰</b><br/>人均 HK$45–90<br/>中环 47 Staunton Street<br/>13:00–22:00]]></description>
      <styleUrl>#dessert</styleUrl>
      <Point><coordinates>114.1530,22.2822,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>聪嫂甜品</name>
      <description><![CDATA[<b>港式糖水</b><br/>人均 HK$40–70<br/>铜锣湾 Sharp Street East 33号<br/>榴莲冰、龙眼冰<br/>顺路吃，不值得专程]]></description>
      <styleUrl>#dessert</styleUrl>
      <Point><coordinates>114.1821,22.2778,0</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Pie &amp; Tart</name>
      <description><![CDATA[<b>平价面包外带</b><br/>人均 HK$10–30<br/>尖沙咀 Granville Road 77号<br/>鲜奶撻、朱古力冻拉<br/>路过顺手买]]></description>
      <styleUrl>#dessert</styleUrl>
      <Point><coordinates>114.1770,22.2988,0</coordinates></Point>
    </Placemark>
  </Folder>

  <!-- ===== Brunch ===== -->
  <Folder>
    <name>🥐 Brunch</name>
    <Placemark>
      <name>Baked</name>
      <description><![CDATA[<b>老牌Brunch</b><br/>人均 HK$150–250<br/>中环 14 Elgin Street, SoHo<br/>招牌 "Oh My God" 黑松露蘑菇酸种面包<br/>和Bouillon、22 Ships同片区]]></description>
      <styleUrl>#brunch</styleUrl>
      <Point><coordinates>114.1528,22.2830,0</coordinates></Point>
    </Placemark>
  </Folder>

</Document>
</kml>
